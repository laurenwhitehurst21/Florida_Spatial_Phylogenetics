library(sf)
library(ggplot2)
library(rnaturalearth)
library(rnaturalearthdata)

fl_outline <- ne_states(country = "United States of America", returnclass = "sf") |>
  subset(name == "Florida") |>
  st_union()

p <- ggplot() +
  geom_sf(data = cons, aes(fill = MATYPE2), color = NA) +
  scale_fill_manual(values = c(
    "Federal" = "#1b9e77",
    "State" = "#d95f02",
    "Local" = "#7570b3",
    "Private" = "#e7298a",
    "Other" = "grey70"
  )) +
  labs(
    title = "Florida Conservation Lands by Authority",
    fill = "Managing Authority",
    caption = "Data source: Florida Natural Areas Inventory (FNAI), 2026"
  ) +
  geom_sf(data = fl_outline, fill = NA, color = "black", linewidth = 0.4) +
  theme_void() + 
  theme(plot.title = element_text(hjust = 0.5, face = "bold", size = 16)
  )
p
