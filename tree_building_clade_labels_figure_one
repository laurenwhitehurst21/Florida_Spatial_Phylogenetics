#for a clade in the list, find the MRCA and highlight that clade with a random color and its label
for (clade in names(clade_list)) {
  node <- MRCA(tree, clade_list[[clade]])
  p <- p + geom_hilight(node = node, fill = sample(colors(), 1), alpha = 0.4) +
 geom_cladelabel(node = node, label = clade, offset = 5, align = TRUE)
}
p

